<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h2 class="mb-0">Modules</h2>
    <small class="text-muted">Browse modules by course, department, and semester</small>
  </div>
  <div class="d-flex gap-2">
    <a href="/modules/structured" class="btn btn-outline-secondary">Structured View</a>
    <% if (user && user.role === 'admin') { %>
      <a href="/modules/new" class="btn btn-primary">Add Module</a>
    <% } %>
  </div>
  
</div>
<%- include('../partials/alerts') %>
<form method="GET" class="row g-2 align-items-end mb-3">
  <div class="col-md-3">
    <label class="form-label mb-1">Course</label>
    <select name="course" class="form-select">
      <option value="">All Courses</option>
      <% courses.forEach(c => { %>
        <option value="<%= c._id %>" <%= String(filters.course) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label mb-1">Department</label>
    <select name="department" class="form-select">
      <option value="">All Departments</option>
      <% departments.forEach(dep => { %>
        <option value="<%= dep._id %>" <%= String(filters.department) === String(dep._id) ? 'selected' : '' %>><%= dep.name %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label mb-1">Semester</label>
    <select name="semester" class="form-select">
      <option value="">All Semesters</option>
      <% semesters.forEach(s => { %>
        <option value="<%= s %>" <%= String(filters.semester) === String(s) ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label mb-1">Search</label>
    <input type="text" name="search" class="form-control" placeholder="Name, code, description" value="<%= filters.search %>" />
  </div>
  <div class="col-md-2 d-grid mt-2 mt-md-0">
    <button class="btn btn-outline-secondary">Apply Filters</button>
  </div>
  <div class="col-md-2 d-grid mt-2 mt-md-0">
    <a href="/modules" class="btn btn-light border">Reset</a>
  </div>
</form>
<div class="table-container">
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Name</th>
        <th>Code</th>
        <th>Course</th>
        <th>Department</th>
        <th>Semester</th>
        <th>Core</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!modules || modules.length === 0) { %>
        <tr>
          <td colspan="7" class="text-center text-muted py-4">No modules found for the selected filters.</td>
        </tr>
      <% } %>
      <% modules.forEach(m => { %>
        <tr>
          <td><a href="/modules/<%= m._id %>"><%= m.name %></a></td>
          <td><%= m.code %></td>
          <td><%= m.course?.name %></td>
          <td><%= m.department?.name %></td>
          <td><%= m.semester %></td>
          <td><%= m.isCore ? 'Yes' : 'No' %></td>
          <td>
            <% if (user && user.role === 'admin') { %>
              <a href="/modules/<%= m._id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
              <form action="/modules/<%= m._id %>?_method=DELETE" method="POST" class="d-inline">
                <button class="btn btn-sm btn-outline-danger" data-confirm="Delete this module?">Delete</button>
              </form>
            <% } else { %>
              -
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
