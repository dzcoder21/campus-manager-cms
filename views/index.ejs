<section class="hero-section">
    <video class="hero-video" autoplay muted loop>
        <source src="/images/CMS.mp4" type="video/mp4">
        Your browser does not support the video tag.
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1 class="hero-title">Welcome to University CMS</h1>
        <p class="hero-subtitle">Manage your university's departments, courses, and modules efficiently.</p>
        <div class="hero-buttons">
            <a href="/departments" class="btn btn-hero-primary">Explore Departments</a>
            <a href="/courses" class="btn btn-hero-outline">View Courses</a>
            <button class="btn btn-hero-login" onclick="openLoginModal()">
                <i class="fas fa-sign-in-alt me-2"></i>Login
            </button>
        </div>
    </div>
</section>

<!-- Find With ChatGPT Section -->
<section id="chatgpt-assistant" class="study-section study-section-light">
    <div class="container">
        <div class="chatgpt-assistant-card">
            <div class="chatgpt-assistant-header">
                <div class="chatgpt-logo-badge" aria-hidden="true">
                    <i class="fas fa-robot"></i>
                </div>
                <div>
                    <h2 class="chatgpt-assistant-title mb-1">ChatGPT Assistant</h2>
                    <p class="chatgpt-assistant-subtitle mb-0">find with chat gpt</p>
                </div>
            </div>

            <p class="chatgpt-assistant-help">Ask anything about departments, courses, modules, login, students, and certificates.</p>

            <form id="chatgptAssistantForm" class="chatgpt-assistant-form" autocomplete="off">
                <div class="chatgpt-input-wrap">
                    <input
                        id="chatgptAssistantInput"
                        type="text"
                        class="form-control"
                        placeholder="Type your question here"
                        maxlength="250"
                        required
                    >
                    <button type="submit" class="btn btn-chatgpt-ask">Ask</button>
                </div>
            </form>

            <div class="chatgpt-answer-panel" id="chatgptAnswerPanel" aria-live="polite">
                Ask a question to see the answer.
            </div>
        </div>
    </div>
</section>

<!-- Login Modal -->
<div class="login-modal" id="loginModal">
    <div class="login-modal-content">
        <div class="login-modal-header">
            <h3 class="login-modal-title">
                <i class="fas fa-user-graduate me-2"></i>Login to University CMS
            </h3>
            <button class="login-modal-close" onclick="closeLoginModal()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="login-modal-body">
            <form action="/login" method="POST">
                <div class="form-group mb-3">
                    <label class="form-label">
                        <i class="fas fa-envelope me-1"></i>Email Address
                    </label>
                    <input type="email" name="email" class="form-control form-control-lg" placeholder="Enter your email" required>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">
                        <i class="fas fa-lock me-1"></i>Password
                    </label>
                    <input type="password" name="password" class="form-control form-control-lg" placeholder="Enter your password" required>
                </div>
                <div class="form-group mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMe">
                        <label class="form-check-label" for="rememberMe">
                            Remember me
                        </label>
                    </div>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-login-submit">
                        <i class="fas fa-sign-in-alt me-2"></i>Login
                    </button>
                </div>
            </form>
            <div class="login-modal-footer">
                <p class="mb-0">
                    Don't have an account? <a href="#" class="login-link">Contact Admin</a>
                </p>
                <p class="mb-0">
                    <a href="#" class="login-link">Forgot Password?</a>
                </p>
            </div>
        </div>
    </div>
</div>

