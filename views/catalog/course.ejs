<div class="mb-3 d-flex justify-content-between align-items-center">
  <a href="/catalog/department/<%= course.department?._id %>" class="btn btn-outline-secondary btn-sm">Back to Department</a>
  <a href="/modules/structured" class="btn btn-outline-secondary btn-sm">All Modules (Structured)</a>
</div>

<h2 class="mb-1"><%= course.name %> (<%= course.code %>)</h2>
<p class="text-muted mb-3"><strong>Department:</strong> <a href="/catalog/department/<%= course.department?._id %>"><%= course.department?.name %></a></p>

<% if (course.description) { %>
  <p><%= course.description %></p>
<% } %>

<hr/>
<h4>Modules by Semester</h4>

<% if (!semesters.length) { %>
  <div class="alert alert-info">No modules defined for this course.</div>
<% } %>

<div class="accordion" id="semAccordion">
  <% semesters.forEach((s, idx) => { %>
    <div class="accordion-item">
      <h2 class="accordion-header" id="heading-<%= s %>">
        <button class="accordion-button <%= idx === 0 ? '' : 'collapsed' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-<%= s %>" aria-expanded="<%= idx === 0 ? 'true' : 'false' %>" aria-controls="collapse-<%= s %>">
          Semester <%= s %>
        </button>
      </h2>
      <div id="collapse-<%= s %>" class="accordion-collapse collapse <%= idx === 0 ? 'show' : '' %>" aria-labelledby="heading-<%= s %>" data-bs-parent="#semAccordion">
        <div class="accordion-body">
          <div class="table-container">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Code</th>
                  <th>Name</th>
                  <th>Credits</th>
                  <th>Core</th>
                  <th>Lecturer</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% (bySemester[s] || []).forEach(m => { %>
                  <tr>
                    <td><%= m.code %></td>
                    <td><a href="/modules/<%= m._id %>"><%= m.name %></a></td>
                    <td><%= m.credits %></td>
                    <td><%= m.isCore ? 'Yes' : 'No' %></td>
                    <td><%= m.lecturer || '-' %></td>
                    <td class="text-end">
                      <a class="btn btn-sm btn-outline-primary" href="/modules/<%= m._id %>">View</a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>
