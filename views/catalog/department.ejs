<div class="mb-3">
  <a href="/catalog" class="btn btn-outline-secondary btn-sm">Back to Catalog</a>
</div>
<h2 class="mb-3"><%= department.name %> (<%= department.code %>)</h2>
<p class="text-muted"><%= department.description || '' %></p>
<hr/>
<h4>Courses</h4>
<div class="row g-3">
  <% if (!courses.length) { %>
    <div class="col-12"><div class="alert alert-info">No courses available for this department.</div></div>
  <% } %>
  <% courses.forEach(c => { %>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= c.name %> (<%= c.code %>)</h5>
          <p class="card-text"><%= (c.description || '').slice(0,140) %><%= (c.description && c.description.length>140) ? '…' : '' %></p>
          <div class="mt-auto">
            <a href="/catalog/course/<%= c._id %>" class="btn btn-outline-primary btn-sm">View Course</a>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>
