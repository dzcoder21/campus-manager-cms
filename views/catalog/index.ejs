<div class="mb-4">
  <h2>Explore Programs</h2>
  <p class="text-muted">Browse departments, courses, and module structures.</p>
</div>

<h4 class="mb-3">Departments</h4>
<div class="row g-3 mb-4">
  <% departments.forEach(dep => { %>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= dep.name %> (<%= dep.code %>)</h5>
          <p class="card-text"><%= dep.description || '' %></p>
          <div class="mt-auto">
            <a href="/catalog/department/<%= dep._id %>" class="btn btn-outline-primary btn-sm">View Department</a>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<h4 class="mb-3">Featured Courses</h4>
<div class="row g-3">
  <% courses.forEach(c => { %>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= c.name %> (<%= c.code %>)</h5>
          <p class="card-subtitle text-muted mb-2"><%= c.department?.name %></p>
          <p class="card-text"><%= (c.description || '').slice(0,140) %><%= (c.description && c.description.length>140) ? '…' : '' %></p>
          <div class="mt-auto">
            <a href="/catalog/course/<%= c._id %>" class="btn btn-outline-secondary btn-sm">View Course</a>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>
