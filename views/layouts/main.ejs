<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Floating Icons -->
    <div class="floating-icons whatsapp-icon">
        <a href="tel:+1234567890" class="floating-icon call-float" title="Call Us">
            <i class="fas fa-phone"></i>
        </a>
        <a href="https://wa.me/1234567890" class="floating-icon whatsapp-float" title="WhatsApp">
            <i class="fab fa-whatsapp"></i>
        </a>
    </div>
    
    <div class="floating-icons chat-icon">
        <a href="/#chatgpt-assistant" class="floating-icon chat-float chatgpt-float" title="Find with ChatGPT" onclick="openChat(event)">
            <i class="fas fa-robot"></i>
            <span class="chatgpt-float-text">Find with ChatGPT</span>
        </a>
    </div>

    <nav class="navbar navbar-expand-lg navbar-dark" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/" style="font-size: 1.5rem;">
                <i class="fas fa-graduation-cap me-2"></i>University CMS
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/departments"><i class="fas fa-building me-1"></i>Departments</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/courses"><i class="fas fa-book me-1"></i>Courses</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/modules"><i class="fas fa-cube me-1"></i>Modules</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/catalog"><i class="fas fa-list me-1"></i>Catalog</a>
                    </li>
                    <% if (user && user.role === 'admin') { %>
                      <li class="nav-item">
                          <a class="nav-link" href="/students"><i class="fas fa-user-graduate me-1"></i>Students</a>
                      </li>
                    <% } %>
                                        <% if (user && user.role === 'student') { %>
                                            <li class="nav-item">
                                                <a class="nav-link" href="/portal/my-courses"><i class="fas fa-book-reader me-1"></i>My Courses</a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link" href="/portal/certificates"><i class="fas fa-certificate me-1"></i>My Certificates</a>
                                            </li>
                                        <% } %>
                    <% if (user && user.role === 'admin') { %>
                      <li class="nav-item dropdown">
                          <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                              <i class="fas fa-plus me-1"></i>Add
                          </a>
                          <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                              <li><a class="dropdown-item" href="/departments/new"><i class="fas fa-building me-2"></i>Add Department</a></li>
                              <li><a class="dropdown-item" href="/courses/new"><i class="fas fa-book me-2"></i>Add Course</a></li>
                              <li><a class="dropdown-item" href="/modules/new"><i class="fas fa-cube me-2"></i>Add Module</a></li>
                              <li><a class="dropdown-item" href="/students/new"><i class="fas fa-user-graduate me-2"></i>Add Student</a></li>
                              <li><hr class="dropdown-divider"></li>
                              <li><a class="dropdown-item" href="/admin/quick-add"><i class="fas fa-bolt me-2"></i>Quick Add</a></li>
                          </ul>
                      </li>
                    <% } %>
                </ul>
                <ul class="navbar-nav">
                  <% if (user) { %>
                    <li class="nav-item">
                      <span class="navbar-text me-2"><i class="fas fa-user me-1"></i>Hello, <%= user.name %></span>
                    </li>
                    <li class="nav-item">
                      <form action="/logout" method="POST">
                        <button class="btn btn-sm btn-light"><i class="fas fa-sign-out-alt me-1"></i>Logout</button>
                      </form>
                    </li>
                  <% } else { %>
                    <li class="nav-item">
                      <a class="btn btn-sm btn-light" href="/login"><i class="fas fa-sign-in-alt me-1"></i>Login</a>
                    </li>
                  <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <%- body %>
    </div>

    <footer class="footer mt-5 py-5">
        <div class="container footer-content">
            <div class="row">
                <div class="col-lg-4 col-md-6 footer-section">
                    <div class="footer-section">
                        <h5 class="footer-title">
                            <i class="fas fa-graduation-cap me-2"></i>University CMS
                        </h5>
                        <p class="footer-description">
                            Transforming lives through excellence in education. We are committed to providing world-class learning experiences that prepare students for global success.
                        </p>
                        <div class="social-icons">
                            <a href="#" class="social-icon" title="Facebook">
                                <i class="fab fa-facebook-f"></i>
                            </a>
                            <a href="#" class="social-icon" title="Twitter">
                                <i class="fab fa-twitter"></i>
                            </a>
                            <a href="#" class="social-icon" title="LinkedIn">
                                <i class="fab fa-linkedin-in"></i>
                            </a>
                            <a href="#" class="social-icon" title="Instagram">
                                <i class="fab fa-instagram"></i>
                            </a>
                            <a href="#" class="social-icon" title="YouTube">
                                <i class="fab fa-youtube"></i>
                            </a>
                        </div>
                        <div class="footer-badge">
                            <i class="fas fa-award me-1"></i>Excellence in Education
                        </div>
                    </div>
                    
                    <div class="footer-section mt-4">
                        <h5 class="footer-title">
                            <i class="fas fa-envelope me-2"></i>Newsletter
                        </h5>
                        <p class="footer-description">Stay updated with our latest news and announcements.</p>
                        <form class="newsletter-form">
                            <input type="email" class="newsletter-input" placeholder="Enter your email address">
                            <button type="submit" class="newsletter-btn">
                                <i class="fas fa-paper-plane me-2"></i>Subscribe
                            </button>
                        </form>
                    </div>
                </div>
                
                <div class="col-lg-2 col-md-6 footer-section">
                    <h5 class="footer-title">
                        <i class="fas fa-link me-2"></i>Quick Links
                    </h5>
                    <ul class="footer-links">
                        <li><a href="/"><i class="fas fa-home"></i>Home</a></li>
                        <li><a href="/departments"><i class="fas fa-building"></i>Departments</a></li>
                        <li><a href="/courses"><i class="fas fa-book"></i>Courses</a></li>
                        <li><a href="/modules"><i class="fas fa-cube"></i>Modules</a></li>
                        <li><a href="/catalog"><i class="fas fa-list"></i>Catalog</a></li>
                        <li><a href="/about"><i class="fas fa-info-circle"></i>About Us</a></li>
                        <li><a href="/admissions"><i class="fas fa-user-plus"></i>Admissions</a></li>
                        <li><a href="/research"><i class="fas fa-microscope"></i>Research</a></li>
                    </ul>
                </div>
                
                <div class="col-lg-3 col-md-6 footer-section">
                    <h5 class="footer-title">
                        <i class="fas fa-university me-2"></i>Academic Programs
                    </h5>
                    <ul class="footer-links">
                        <li><a href="#"><i class="fas fa-laptop-code"></i>Computer Science</a></li>
                        <li><a href="#"><i class="fas fa-briefcase"></i>Business Administration</a></li>
                        <li><a href="#"><i class="fas fa-heartbeat"></i>Health Sciences</a></li>
                        <li><a href="#"><i class="fas fa-palette"></i>Arts & Design</a></li>
                        <li><a href="#"><i class="fas fa-gavel"></i>Law Studies</a></li>
                        <li><a href="#"><i class="fas fa-flask"></i>Engineering</a></li>
                        <li><a href="#"><i class="fas fa-graduation-cap"></i>Education</a></li>
                        <li><a href="#"><i class="fas fa-globe"></i>International Studies</a></li>
                    </ul>
                </div>
                
                <div class="col-lg-3 col-md-6 footer-section">
                    <h5 class="footer-title">
                        <i class="fas fa-contact-card me-2"></i>Contact Information
                    </h5>
                    <ul class="contact-info">
                        <li>
                            <i class="fas fa-map-marker-alt"></i>
                            <span>123 University Avenue<br>Education City, EC 12345</span>
                        </li>
                        <li>
                            <i class="fas fa-phone-alt"></i>
                            <span>+91 95095 61817</span>
                        </li>
                        <li>
                            <i class="fas fa-envelope"></i>
                            <span>info@university-cms.edu<br>admissions@university-cms.edu</span>
                        </li>
                        <li>
                            <i class="fas fa-clock"></i>
                            <span>Mon-Fri: 8:00 AM - 6:00 PM<br>Sat-Sun: 9:00 AM - 2:00 PM</span>
                        </li>
                    </ul>
                    
                    <div class="mt-4">
                        <h5 class="footer-title">
                            <i class="fas fa-certificate me-2"></i>Accreditation
                        </h5>
                        <p class="footer-description">
                            Fully accredited by the Higher Learning Commission and recognized globally for academic excellence.
                        </p>
                        <div class="footer-badge">
                            <i class="fas fa-check-circle me-1"></i>Accredited Institution
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="footer-bottom">
                <p class="footer-copyright mb-2">
                    © 2024 University CMS. All rights reserved. | Designed with Sanjeevani Sharma for Educational
                </p>
                <div class="mt-2">
                    <a href="/privacy" class="footer-copyright me-3">Privacy Policy</a>
                    <a href="/terms" class="footer-copyright me-3">Terms of Service</a>
                    <a href="/accessibility" class="footer-copyright me-3">Accessibility</a>
                    <a href="/sitemap" class="footer-copyright">Sitemap</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script>
        function openChat(event) {
            if (event) event.preventDefault();
            window.location.href = '/#chatgpt-assistant';
        }

        function openLoginModal() {
            document.getElementById('loginModal').style.display = 'block';
        }

        function closeLoginModal() {
            document.getElementById('loginModal').style.display = 'none';
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('loginModal');
            if (event.target == modal) {
                modal.style.display = 'none';
            }
        }
    </script>
</body>
</html>
