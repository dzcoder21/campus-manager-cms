<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h2 class="mb-0">Edit Student</h2>
    <small class="text-muted">Update student details, status, and login settings</small>
  </div>
  <a class="btn btn-outline-secondary" href="/students/<%= student._id %>">Back to Student</a>
</div>
<%- include('../partials/alerts') %>
<div class="form-container">
  <form action="/students/<%= student._id %>?_method=PUT" method="POST">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Full Name</label>
        <input type="text" name="name" class="form-control" value="<%= student.name %>" required />
      </div>
      <div class="col-md-6">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" value="<%= student.email %>" required />
      </div>
      <div class="col-md-6">
        <label class="form-label">Roll Number</label>
        <input type="text" name="rollNumber" class="form-control" value="<%= student.rollNumber %>" required />
      </div>
      <div class="col-md-6">
        <label class="form-label">Department</label>
        <select name="department" class="form-select" required>
          <% departments.forEach(dep => { %>
            <option value="<%= dep._id %>" <%= String(student.department) === String(dep._id) ? 'selected' : '' %>><%= dep.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-6">
        <label class="form-label">Course</label>
        <select name="course" class="form-select" required>
          <% courses.forEach(c => { %>
            <option value="<%= c._id %>" <%= String(student.course) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Year</label>
        <input type="number" name="year" class="form-control" min="1" max="10" value="<%= student.year %>" />
      </div>
      <div class="col-md-3">
        <label class="form-label">Semester</label>
        <input type="number" name="semester" class="form-control" min="1" max="12" value="<%= student.semester %>" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Enrollment Date</label>
        <input type="date" name="enrollmentDate" class="form-control" value="<%= new Date(student.enrollmentDate).toISOString().slice(0,10) %>" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
          <% ['active','graduated','on_leave','inactive'].forEach(s => { %>
            <option value="<%= s %>" <%= student.status === s ? 'selected' : '' %>><%= s.replace('_', ' ').replace(/\b\w/g, c => c.toUpperCase()) %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-12">
        <label class="form-label">Notes</label>
        <textarea name="notes" class="form-control" rows="3"><%= student.notes %></textarea>
      </div>
    </div>

    <hr class="mt-4" />
    <% if (!student.user) { %>
      <div class="mb-2">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="createLogin" id="createLogin" />
          <label class="form-check-label" for="createLogin">Create login for this student</label>
        </div>
      </div>
      <div class="row g-3">
        <div class="col-md-6" id="passwordFieldWrap">
          <label class="form-label">Initial Password (min 6 chars)</label>
          <div class="input-group">
            <input type="password" name="password" id="studentPassword" class="form-control" placeholder="Set a temporary password" minlength="6" />
            <button class="btn btn-outline-secondary" type="button" id="toggleStudentPassword" aria-label="Show or hide password">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Reset Password (optional)</label>
          <div class="input-group">
            <input type="password" name="resetPassword" id="resetPassword" class="form-control" placeholder="Enter new password (min 6 chars)" />
            <button class="btn btn-outline-secondary" type="button" id="toggleResetPassword" aria-label="Show or hide password">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>
      </div>
    <% } %>
    <div class="mt-3">
      <button class="btn btn-primary">Update</button>
      <a class="btn btn-secondary" href="/students/<%= student._id %>">Cancel</a>
    </div>
  </form>
</div>

<script>
  (function () {
    const createLogin = document.getElementById('createLogin');
    const passwordField = document.getElementById('studentPassword');
    const passwordWrap = document.getElementById('passwordFieldWrap');
    const togglePassword = document.getElementById('toggleStudentPassword');
    const resetPasswordField = document.getElementById('resetPassword');
    const toggleResetPassword = document.getElementById('toggleResetPassword');

    if (createLogin && passwordField && passwordWrap) {
      const syncPasswordField = () => {
        const enabled = createLogin.checked;
        passwordField.required = enabled;
        passwordField.disabled = !enabled;
        passwordWrap.style.opacity = enabled ? '1' : '0.6';
        if (!enabled) {
          passwordField.value = '';
        }
      };

      createLogin.addEventListener('change', syncPasswordField);
      if (togglePassword) {
        togglePassword.addEventListener('click', () => {
          const isPassword = passwordField.type === 'password';
          passwordField.type = isPassword ? 'text' : 'password';
          togglePassword.innerHTML = isPassword ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
        });
      }
      syncPasswordField();
    }

    if (resetPasswordField && toggleResetPassword) {
      toggleResetPassword.addEventListener('click', () => {
        const isPassword = resetPasswordField.type === 'password';
        resetPasswordField.type = isPassword ? 'text' : 'password';
        toggleResetPassword.innerHTML = isPassword ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
      });
    }
  })();
</script>
