<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h2 class="mb-0">Add Student</h2>
    <small class="text-muted">Create a new student profile and optional login account</small>
  </div>
  <a class="btn btn-outline-secondary" href="/students">Back to Students</a>
</div>
<%- include('../partials/alerts') %>
<div class="form-container">
  <form action="/students" method="POST">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Full Name</label>
        <input type="text" name="name" class="form-control" required />
      </div>
      <div class="col-md-6">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" required />
      </div>
      <div class="col-md-6">
        <label class="form-label">Roll Number</label>
        <input type="text" name="rollNumber" class="form-control" required />
      </div>
      <div class="col-md-6">
        <label class="form-label">Department</label>
        <select name="department" class="form-select" required>
          <% departments.forEach(dep => { %>
            <option value="<%= dep._id %>"><%= dep.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-6">
        <label class="form-label">Course</label>
        <select name="course" class="form-select" required>
          <% courses.forEach(c => { %>
            <option value="<%= c._id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Year</label>
        <input type="number" name="year" class="form-control" min="1" max="10" value="1" />
      </div>
      <div class="col-md-3">
        <label class="form-label">Semester</label>
        <input type="number" name="semester" class="form-control" min="1" max="12" value="1" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Enrollment Date</label>
        <input type="date" name="enrollmentDate" class="form-control" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
          <option value="active" selected>Active</option>
          <option value="graduated">Graduated</option>
          <option value="on_leave">On Leave</option>
          <option value="inactive">Inactive</option>
        </select>
      </div>
      <div class="col-12">
        <label class="form-label">Notes</label>
        <textarea name="notes" class="form-control" rows="3"></textarea>
      </div>

      <hr class="mt-4" />
      <div class="col-12">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="createLogin" id="createLogin" checked />
          <label class="form-check-label" for="createLogin">Create login for this student now</label>
        </div>
      </div>
      <div class="col-md-6" id="passwordFieldWrap">
        <label class="form-label">Initial Password (min 6 chars)</label>
        <div class="input-group">
          <input type="password" name="password" id="studentPassword" class="form-control" placeholder="Set a temporary password" minlength="6" required />
          <button class="btn btn-outline-secondary" type="button" id="toggleStudentPassword" aria-label="Show or hide password">
            <i class="fas fa-eye"></i>
          </button>
        </div>
      </div>
    </div>
    <div class="mt-3">
      <button class="btn btn-primary">Create</button>
      <a class="btn btn-secondary" href="/students">Cancel</a>
    </div>
  </form>
</div>

<script>
  (function () {
    const createLogin = document.getElementById('createLogin');
    const passwordField = document.getElementById('studentPassword');
    const passwordWrap = document.getElementById('passwordFieldWrap');
    const togglePassword = document.getElementById('toggleStudentPassword');

    if (!createLogin || !passwordField || !passwordWrap) return;

    const syncPasswordField = () => {
      const enabled = createLogin.checked;
      passwordField.required = enabled;
      passwordField.disabled = !enabled;
      passwordWrap.style.opacity = enabled ? '1' : '0.6';
      if (!enabled) {
        passwordField.value = '';
      }
    };

    createLogin.addEventListener('change', syncPasswordField);

    if (togglePassword) {
      togglePassword.addEventListener('click', () => {
        const isPassword = passwordField.type === 'password';
        passwordField.type = isPassword ? 'text' : 'password';
        togglePassword.innerHTML = isPassword ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
      });
    }

    syncPasswordField();
  })();
</script>
